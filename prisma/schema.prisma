// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
}

model Guestbook {
  id      Int      @id @default(autoincrement())
  author  String
  content String
  date    String
  avatar  String
}

model ArticleComment {
  id      Int      @id @default(autoincrement())
  postId  String
  author  String
  content String
  date    String
  avatar  String
}
